{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/riff/destructive-guard.sh \"$TOOL_INPUT\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/riff/boundary-check.sh \"$TOOL_INPUT\""
					},
					{
						"type": "command",
						"command": "bash .claude/hooks/riff/typecheck-gate.sh \"$TOOL_INPUT\""
					},
					{
						"type": "command",
						"command": "bash .claude/hooks/riff/lint-gate.sh \"$TOOL_INPUT\""
					},
					{
						"type": "command",
						"command": "bash .claude/hooks/riff/test-gate.sh \"$TOOL_INPUT\""
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"$(git -C \"$PWD\" rev-parse --show-toplevel 2>/dev/null || echo \"$PWD\")\" && git diff --quiet && git diff --cached --quiet && [ -z \"$(git ls-files --others --exclude-standard)\" ] || (git add -A && git commit -m \"chore: auto-commit $(date '+%Y-%m-%d %H:%M')\" && git push 2>/dev/null || true)"
					}
				]
			}
		]
	}
}
