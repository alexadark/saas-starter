# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find all values at: Supabase Dashboard → Project Settings → API

# Project URL — Dashboard label: "Project URL"
VITE_SUPABASE_URL=https://your-project.supabase.co

# Publishable key — safe to expose to browser (secured by RLS)
# Dashboard label: "publishable" (formerly "anon / public")
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret key — server ONLY, bypasses RLS, NEVER add VITE_ prefix
# Dashboard label: "secret" (formerly "service_role")
SUPABASE_SECRET_KEY=your-secret-key

# ─── Database (Drizzle ORM) ───────────────────────────────────────────────────
# Transaction pooler URL — "Connect" button (top right) → Transaction mode → port 6543
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
